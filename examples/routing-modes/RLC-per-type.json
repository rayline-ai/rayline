{
  "endpoints": [
    {
      "id": "rayline-cloud",
      "protocol": "anthropic_messages",
      "base_url": "https://api.rayline.ai",
      "api_key_env": "RAYLINE_ROUTER_API_KEY",
      "auth": "api_key",
      "models": [
        "rayline-router"
      ]
    },
    {
      "id": "ollama",
      "protocol": "openai_chat",
      "base_url": "http://127.0.0.1:11434/v1",
      "models": [
        "qwen3.5:9b",
        "qwen2.5-coder:7b"
      ]
    }
  ],
  "routes": {
    "main": {
      "endpoint": "rayline-cloud",
      "model": "rayline-router"
    },
    "subagent": {
      "endpoint": "rayline-cloud",
      "model": "rayline-router"
    },
    "subagents": {
      "Explore": {
        "endpoint": "ollama",
        "model": "qwen2.5-coder:7b"
      },
      "Plan": {
        "endpoint": "ollama",
        "model": "qwen3.5:9b"
      }
    }
  }
}
