{
  "endpoints": [
    { "id": "rayline-cloud", "protocol": "anthropic_messages", "base_url": "https://api.rayline.ai",
      "api_key_env": "RAYLINE_ROUTER_API_KEY", "auth": "api_key", "models": ["rayline-router"] },
    { "id": "anthropic", "protocol": "anthropic_messages", "base_url": "https://api.anthropic.com",
      "api_key_env": "ANTHROPIC_API_KEY", "auth": "api_key", "models": ["claude-sonnet-4-6"] },
    { "id": "ollama", "protocol": "openai_chat", "base_url": "http://127.0.0.1:11434/v1",
      "models": ["qwen2.5-coder:7b"] }
  ],
  "routes": {
    "main":     { "endpoint": "rayline-cloud", "model": "rayline-router", "router": "rayline-cloud", "local_models": ["qwen2.5-coder:7b"] },
    "subagent": { "endpoint": "anthropic", "model": "claude-sonnet-4-6" }
  }
}
