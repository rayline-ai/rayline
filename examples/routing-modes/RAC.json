{
  "endpoints": [
    {
      "id": "rayline-cloud",
      "protocol": "anthropic_messages",
      "base_url": "https://api.rayline.ai",
      "api_key_env": "RAYLINE_ROUTER_API_KEY",
      "auth": "api_key",
      "models": [
        "rayline-router"
      ]
    },
    {
      "id": "anthropic",
      "protocol": "anthropic_messages",
      "base_url": "https://api.anthropic.com",
      "api_key_env": "ANTHROPIC_API_KEY",
      "auth": "api_key",
      "models": [
        "claude-sonnet-4-6"
      ]
    }
  ],
  "routes": {
    "main": {
      "endpoint": "rayline-cloud",
      "model": "rayline-router"
    },
    "subagent": {
      "endpoint": "anthropic",
      "model": "claude-sonnet-4-6"
    }
  }
}
